{
  "FrontendUrl": "http://localhost:3000",
  "Jwt": {
    "Key": "archlens-dev-jwt-secret-key-minimum-32-characters!"
  },
  "ReverseProxy": {
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://auth-api:8080"
          }
        }
      },
      "upload-cluster": {
        "Destinations": {
          "upload": {
            "Address": "http://upload-api:8080"
          }
        }
      },
      "orchestrator-cluster": {
        "Destinations": {
          "orchestrator": {
            "Address": "http://orchestrator-api:8080"
          }
        }
      },
      "report-cluster": {
        "Destinations": {
          "report": {
            "Address": "http://report-api:8080"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "ai": {
            "Address": "http://ai-processing:8080"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": {
            "Address": "http://notification-api:8080"
          }
        }
      },
      "prometheus-cluster": {
        "Destinations": {
          "prometheus": {
            "Address": "http://prometheus:9090"
          }
        }
      },
      "jaeger-cluster": {
        "Destinations": {
          "jaeger": {
            "Address": "http://jaeger:16686"
          }
        }
      }
    }
  }
}
